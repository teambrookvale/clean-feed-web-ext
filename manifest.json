{
  "manifest_version": 3,
  "name": "Clean Feed",
  "version": "0.1.0",
  "description": "Browser extension that filters AI-related feed posts on LinkedIn today, with room to expand to other platforms later.",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.r2.dev/*"
  ],
  "action": {
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    },
    "default_title": "Clean Feed",
    "default_popup": "src/popup/popup.html"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "src/shared/default-patterns.js",
        "src/shared/filter-core.js",
        "src/shared/discovery-rules.js",
        "src/shared/storage.js",
        "src/shared/remote-rules-core.js",
        "src/shared/remote-rules.js",
        "src/content/index.js"
      ],
      "css": [
        "src/content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "linkedin-ai-feed-filter@example.com"
    }
  }
}
